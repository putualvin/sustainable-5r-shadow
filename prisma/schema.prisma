// Sustainable 5R — Prisma schema (SQLite, shadow build)
// Module 0: User + Area only. Schema grows per roadmap module.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Role {
  admin
  komite_unit
  auditor
  auditee
  kord_red_tag
  management
}

// The 5 R principles — level-1 category for audit findings.
enum Pillar {
  RINGKAS
  RAPI
  RESIK
  RAWAT
  RAJIN
}

enum AuditStatus {
  DRAFT
  SUBMITTED
}

// Finding lifecycle for Module 2. CAPA closing statuses live in Module 3.
enum FindingStatus {
  DRAFT
  PENDING_CAPA
}

// CAPA closing status — drives the area score (see lib/scoring.ts).
enum CapaStatus {
  DONE
  PROGRESS
  NO_PROGRESS
}

// Parent grouping for areas; Daily Checklist items are shared per parent group.
enum AreaGroup {
  REFINERY
  FRACTIONATION
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  role      Role     @default(auditee)
  // PIC (auditee) is tied to one area; other roles leave this null.
  areaId    String?
  area      Area?    @relation(fields: [areaId], references: [id])
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  audits    Audit[]
  schedules AuditSchedule[]
}

model Area {
  id        String     @id @default(cuid())
  code      String     @unique
  name      String
  group     AreaGroup?
  active    Boolean    @default(true)
  createdAt DateTime   @default(now())

  pics      User[]
  scores    Score[]
  audits    Audit[]
  schedules AuditSchedule[]
}

// Monthly 5R score per area. In Module 3 these are recomputed from CAPA
// statuses via lib/scoring.ts; for now they are seeded directly.
model Score {
  id              String   @id @default(cuid())
  area            Area     @relation(fields: [areaId], references: [id], onDelete: Cascade)
  areaId          String
  period          String // "YYYY-MM"
  countDone       Int      @default(0)
  countProgress   Int      @default(0)
  countNoProgress Int      @default(0)
  finalScore      Int      @default(0) // computed via lib/scoring.ts
  createdAt       DateTime @default(now())

  @@unique([areaId, period])
  @@index([period])
}

// Official 5R taxonomy (27 sub-categories across the 5 pillars). Used ONLY to
// classify audit findings — NOT the Daily Checklist (separate model later).
model GuidingQuestion {
  id          String   @id @default(cuid())
  pillar      Pillar
  subCategory String // level-2 name shown in the dropdown
  description String // helper text guiding judgement
  order       Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  findings Finding[]

  @@index([pillar])
}

// Who audits which area in a given period (committee-managed).
model AuditSchedule {
  id        String   @id @default(cuid())
  area      Area     @relation(fields: [areaId], references: [id], onDelete: Cascade)
  areaId    String
  auditor   User     @relation(fields: [auditorId], references: [id])
  auditorId String
  period    String // "YYYY-MM"
  dueDate   DateTime?
  createdAt DateTime @default(now())

  audits Audit[]

  @@unique([areaId, period])
  @@index([auditorId, period])
}

// One audit = one auditor inspecting one area in one period.
model Audit {
  id          String        @id @default(cuid())
  area        Area          @relation(fields: [areaId], references: [id])
  areaId      String
  auditor     User          @relation(fields: [auditorId], references: [id])
  auditorId   String
  schedule    AuditSchedule? @relation(fields: [scheduleId], references: [id])
  scheduleId  String?
  period      String // "YYYY-MM"
  status      AuditStatus   @default(DRAFT)
  submittedAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  findings Finding[]

  @@index([auditorId])
  @@index([areaId, period])
}

model Finding {
  id                String          @id @default(cuid())
  audit             Audit           @relation(fields: [auditId], references: [id], onDelete: Cascade)
  auditId           String
  guidingQuestion   GuidingQuestion @relation(fields: [guidingQuestionId], references: [id])
  guidingQuestionId String
  locationDetail    String? // specific spot within the area
  description       String
  photoPath         String? // /uploads/...
  status            FindingStatus   @default(DRAFT)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  capa Capa?

  @@index([auditId])
  @@index([status])
}

// Corrective & Preventive Action — one per finding. No dispute step (rule 3),
// single after-photo (rule 4).
model Capa {
  id               String     @id @default(cuid())
  finding          Finding    @relation(fields: [findingId], references: [id], onDelete: Cascade)
  findingId        String     @unique
  rootCause        String
  correctiveAction String
  preventiveAction String
  afterPhoto       String? // /uploads/... (single photo)
  dueDate          DateTime?
  status           CapaStatus @default(PROGRESS)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
}
