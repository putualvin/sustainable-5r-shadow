// Sustainable 5R — Prisma schema (SQLite, shadow build)
// Module 0: User + Area only. Schema grows per roadmap module.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  admin
  komite_unit
  auditor
  auditee
  kord_red_tag
  management
}

// The 5 R principles — level-1 category for audit findings.
enum Pillar {
  RINGKAS
  RAPI
  RESIK
  RAWAT
  RAJIN
}

enum AuditStatus {
  DRAFT
  SUBMITTED
}

// Finding lifecycle for Module 2. CAPA closing statuses live in Module 3.
enum FindingStatus {
  DRAFT
  PENDING_CAPA
}

// Auditor-assigned category of a finding (§5.1). NOT the closing status.
enum Kategori {
  LOW
  HIGH
}

// CAPA closing status — drives the area score (see lib/scoring.ts).
enum CapaStatus {
  DONE
  PROGRESS
  NO_PROGRESS
}

// Red Tag storage location → retention period (30 vs 90 days).
enum RedTagLocation {
  IN_AREA // disimpan di area, maks 30 hari
  RT_AREA // dipindah ke Red Tag Area, maks 90 hari
}

// Red Tag lifecycle: OPEN until the coordinator decides its disposal.
enum RedTagStatus {
  OPEN
  INTERNAL // digunakan kembali secara internal
  EXTERNAL // dijual / dipindah ke pihak luar
  DISPOSED // dimusnahkan
}

// Parent grouping for areas; Daily Checklist items are shared per parent group.
enum AreaGroup {
  REFINERY
  FRACTIONATION
}

// Document repository categories (Module 7).
enum DocCategory {
  PANDUAN // panduan / guidelines
  SOP // standard operating procedure
  STANDARD // standar area
  TEMPLATE // template / contoh
  FORMULIR // formulir / checklist cetak
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  // A user may hold MULTIPLE roles (e.g. an area PIC who is also an auditor).
  // Access is the union of all roles' permissions (see lib/rbac.ts).
  roles     Role[]   @default([auditee])
  // PIC (auditee) is tied to one area; other roles leave this null.
  areaId    String?
  area      Area?    @relation(fields: [areaId], references: [id])
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  audits    Audit[]
  schedules AuditSchedule[]
}

model Area {
  id        String     @id @default(cuid())
  code      String     @unique
  name      String
  group     AreaGroup?
  active    Boolean    @default(true)
  createdAt DateTime   @default(now())

  pics          User[]
  scores        Score[]
  audits        Audit[]
  schedules     AuditSchedule[]
  checklistRuns ChecklistRun[]
  redTags       RedTag[]
}

// Monthly 5R score per area. In Module 3 these are recomputed from CAPA
// statuses via lib/scoring.ts; for now they are seeded directly.
model Score {
  id              String   @id @default(cuid())
  area            Area     @relation(fields: [areaId], references: [id], onDelete: Cascade)
  areaId          String
  period          String // "YYYY-MM"
  countDone       Int      @default(0)
  countProgress   Int      @default(0)
  countNoProgress Int      @default(0)
  // Two-layer scoring (§5.4), all computed via lib/scoring.ts:
  nilaiUtama      Int      @default(0) // Lapis 1
  temuanBerulang  Int      @default(0) // count recurring (−1 each)
  parkingLot      Int      @default(0) // count Not-Done (tracking; weight 0)
  finalScore      Int      @default(0) // Score Akhir (Lapis 2)
  createdAt       DateTime @default(now())

  @@unique([areaId, period])
  @@index([period])
}

// Official 5R taxonomy (27 sub-categories across the 5 pillars). Used ONLY to
// classify audit findings — NOT the Daily Checklist (separate model later).
model GuidingQuestion {
  id          String   @id @default(cuid())
  pillar      Pillar
  subCategory String // level-2 name shown in the dropdown
  description String // helper text guiding judgement
  order       Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  findings Finding[]

  @@index([pillar])
}

// Who audits which area in a given period (committee-managed).
model AuditSchedule {
  id        String   @id @default(cuid())
  area      Area     @relation(fields: [areaId], references: [id], onDelete: Cascade)
  areaId    String
  auditor   User     @relation(fields: [auditorId], references: [id])
  auditorId String
  period    String // "YYYY-MM"
  dueDate   DateTime?
  createdAt DateTime @default(now())

  audits Audit[]

  @@unique([areaId, period])
  @@index([auditorId, period])
}

// One audit = one auditor inspecting one area in one period.
model Audit {
  id          String        @id @default(cuid())
  area        Area          @relation(fields: [areaId], references: [id])
  areaId      String
  auditor     User          @relation(fields: [auditorId], references: [id])
  auditorId   String
  schedule    AuditSchedule? @relation(fields: [scheduleId], references: [id])
  scheduleId  String?
  period      String // "YYYY-MM"
  status      AuditStatus   @default(DRAFT)
  submittedAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  findings       Finding[]
  findingReviews FindingReview[]

  @@index([auditorId])
  @@index([areaId, period])
}

model Finding {
  id                String          @id @default(cuid())
  audit             Audit           @relation(fields: [auditId], references: [id], onDelete: Cascade)
  auditId           String
  number            Int             @default(0) // nomor temuan urut per audit (area+periode)
  guidingQuestion   GuidingQuestion @relation(fields: [guidingQuestionId], references: [id])
  guidingQuestionId String
  locationDetail    String? // specific spot within the area
  description       String
  kategori          Kategori        @default(LOW) // auditor-assigned (§5.1)
  isRecurring       Boolean         @default(false) // temuan berulang (§5.4)
  photoPath         String? // /uploads/...
  status            FindingStatus   @default(DRAFT)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  capa Capa?
  redTags RedTag[]

  // Pre-audit verification links (§5.4):
  reviewsAsPrev   FindingReview[] @relation("PrevReview")   // reviews of THIS finding next month
  reviewAsCarried FindingReview?  @relation("CarriedReview") // the review that carried this finding in

  @@index([auditId])
  @@index([status])
}

// Pre-audit verification (§5.4): before recording new findings the auditor
// reviews the AREA's previous-period findings and marks each as still present
// (carried into this audit as a recurring finding) or already handled.
model FindingReview {
  id               String   @id @default(cuid())
  audit            Audit    @relation(fields: [auditId], references: [id], onDelete: Cascade)
  auditId          String // the current (reviewing) audit
  prevFinding      Finding  @relation("PrevReview", fields: [prevFindingId], references: [id], onDelete: Cascade)
  prevFindingId    String // a finding from the same area, previous period
  stillExists      Boolean // true = masih ada (berulang), false = sudah ditangani
  // When still present, the recurring finding created in the current audit.
  carriedFinding   Finding? @relation("CarriedReview", fields: [carriedFindingId], references: [id], onDelete: SetNull)
  carriedFindingId String?  @unique
  createdAt        DateTime @default(now())

  @@unique([auditId, prevFindingId])
  @@index([auditId])
}

// Corrective & Preventive Action — one per finding. No dispute step (rule 3),
// single after-photo (rule 4). The auditee fills the plan; the CLOSING STATUS
// is set by Komite Unit during verification (drives the score), not by the
// auditee. `status` is null until verified; once verified the CAPA is locked.
model Capa {
  id               String      @id @default(cuid())
  finding          Finding     @relation(fields: [findingId], references: [id], onDelete: Cascade)
  findingId        String      @unique
  rootCause        String
  correctiveAction String
  preventiveAction String
  woScPoNumber     String? // wajib untuk status Progress (§5.2/§5.3)
  afterPhoto       String? // /uploads/... (single photo)
  dueDate          DateTime?
  status           CapaStatus? // null = menunggu verifikasi Komite Unit
  verifiedAt       DateTime?
  verifiedBy       String? // denormalized Komite Unit name
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
}

// ===== Daily Checklist — COMPLETELY SEPARATE from Audit (rule 6) =====
// Self-check done per shift by the area's own PIC. Items are area-specific,
// scoped to the parent area group (Refinery / Fractionation).

model ChecklistItem {
  id        String    @id @default(cuid())
  group     AreaGroup
  text      String
  order     Int       @default(0)
  active    Boolean   @default(true)
  createdAt DateTime  @default(now())

  responses ChecklistResponse[]

  @@index([group])
}

model ChecklistRun {
  id        String   @id @default(cuid())
  area      Area     @relation(fields: [areaId], references: [id], onDelete: Cascade)
  areaId    String
  date      String // YYYY-MM-DD
  shift     Int // 1, 2, or 3
  score     Int      @default(0) // percent compliant
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  responses ChecklistResponse[]

  @@unique([areaId, date, shift])
  @@index([areaId])
}

model ChecklistResponse {
  id        String        @id @default(cuid())
  run       ChecklistRun  @relation(fields: [runId], references: [id], onDelete: Cascade)
  runId     String
  item      ChecklistItem @relation(fields: [itemId], references: [id])
  itemId    String
  compliant Boolean
  note      String?
  photoPath String?

  @@unique([runId, itemId])
}

// ===== Module 7: Document repository =====
// Versioned 5R reference docs. fileUrl may be an uploaded file (/uploads/..)
// or an external link; uploadedBy is denormalized (mock auth, no FK).
model Document {
  id          String      @id @default(cuid())
  title       String
  category    DocCategory
  version     String      @default("v1.0")
  fileUrl     String? // /uploads/.. or external URL
  description String?
  uploadedBy  String? // denormalized uploader name
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([category])
}

// ===== Module 7: Audit log =====
// Append-only record of notable actions. User identity is denormalized so the
// log survives user edits/deletions.
model AuditLog {
  id        String   @id @default(cuid())
  action    String // machine key, e.g. "user.role.update"
  entity    String // "User" | "AuditSchedule" | "Document" | ...
  summary   String // human-readable (Bahasa)
  userName  String
  userEmail String
  createdAt DateTime @default(now())

  @@index([createdAt])
}

// ===== Red Tag =====
model RedTag {
  id           String         @id @default(cuid())
  tagNumber    String         @unique // RT-YYYY-NNN
  area         Area           @relation(fields: [areaId], references: [id])
  areaId       String
  // Optional link to the audit finding/CAPA that triggered this red tag.
  finding      Finding?       @relation(fields: [findingId], references: [id], onDelete: SetNull)
  findingId    String?
  name         String
  category     String
  reason       String
  location     RedTagLocation
  photoPath    String?
  status       RedTagStatus   @default(OPEN)
  registeredAt DateTime       @default(now())
  dueDate      DateTime
  decidedAt    DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([status])
  @@index([findingId])
}
