# Salin file ini menjadi .env lalu isi nilainya.
# cp .env.example .env

# Database.
# - Lokal (dev cepat): SQLite -> "file:./dev.db"
# - Produksi / Neon (Postgres): connection string Neon, mis.
#   postgresql://USER:PASSWORD@HOST/db?sslmode=require
DATABASE_URL="file:./dev.db"

# Secret untuk menandatangani cookie sesi (mock auth — ganti dengan string acak panjang di produksi).
SESSION_SECRET="ganti-dengan-string-acak-min-32-karakter"
